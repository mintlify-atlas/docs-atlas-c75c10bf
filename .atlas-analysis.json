  "keyFeatures": [
    "Role-based access control with 4 roles: Administrator, Waiter, Cook, Cashier",
    "Product catalog and menu management with CRUD operations",
    "Ingredient inventory tracking with notifications",
    "Table management and order-taking workflow",
    "Kitchen comanda (order ticket) management",
    "Delivery order handling",
    "Invoice generation and payment registration",
    "End-of-day cash register closing",
    "User management (admin only)",
    "Role-specific dashboards with business intelligence views"
